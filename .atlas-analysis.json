  "keyFeatures": [
    "REST API for order submission and queries across multiple chains",
    "Automated auction management via Autopilot service",
    "Driver service for solution execution and on-chain settlement",
    "Internal solver engine with baseline strategies",
    "PostgreSQL-backed order persistence and validation",
    "Multi-chain support (Mainnet, Gnosis, Arbitrum, Base, etc.)",
    "Real-time order validation and fee estimation",
    "Batch auction settlement with MEV protection"
  ],
  "publicApiSurface": [
    "POST /api/v1/orders - Create order",
    "GET /api/v1/orders/{uid} - Get order by UID",
    "GET /api/v1/account/{address}/orders - Get orders by account",
    "POST /api/v1/quote - Get price quote",
    "POST /api/v1/fee - Estimate order fees",
    "GET /api/v1/solvable_orders - Get solvable orders (Autopilot)",
    "POST /api/v1/solve - Submit solution (Driver)",
    "POST /api/v1/reveal - Reveal solution (Driver)",
    "GET /api/v1/settle - Execute settlement (Driver)"
  ]
}
